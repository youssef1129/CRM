# ==============================================================================
# VETCRM - CONFIGURATION GLOBALE (DOCKER)
# ==============================================================================

# --- ENVIRONNEMENT ---
NODE_ENV=development

# --- BASE DE DONNÉES (POSTGRES) ---
# Ces variables sont utilisées par le service 'db' et transmises au backend
DB_USER=crm_admin
DB_PASSWORD=crm_secure_password_123
DB_NAME=crm_database
# Port exposé sur la machine hôte
DB_PORT=8099

# --- CONFIGURATION API & FRONTEND ---
# URL utilisée par le navigateur pour contacter l'API
NEXT_PUBLIC_API_URL=http://localhost:8098
# Port exposé pour le frontend
FRONTEND_PORT=3000
# Port exposé pour le backend
BACKEND_PORT=8098

# --- DOCKER ---
# Nom du projet Docker Compose
COMPOSE_PROJECT_NAME=vetcrm
