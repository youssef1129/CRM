# ==============================================================================
# VETCRM - CONFIGURATION FRONTEND (NEXT.JS)
# ==============================================================================

# --- API ---

# [CLIENT-SIDE] URL de l'API accessible depuis le navigateur.
# En local/Docker : http://localhost:8098
NEXT_PUBLIC_API_URL=http://localhost:8098

# [SERVER-SIDE] URL de l'API utilisée par Next.js pour le SSR.
# En local : http://localhost:8098
# En Docker : http://backend:8098
INTERNAL_API_URL=http://localhost:8098
